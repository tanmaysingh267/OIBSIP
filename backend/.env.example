# Database
MONGODB_URI=mongodb://localhost:27017/pizza-delivery

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Server
PORT=5000
NODE_ENV=development

# Admin Email
ADMIN_EMAIL=admin@pizzadelivery.com

# Stock Threshold
STOCK_THRESHOLD_BASE=20
STOCK_THRESHOLD_SAUCE=20
STOCK_THRESHOLD_CHEESE=20
STOCK_THRESHOLD_VEGGIES=30
STOCK_THRESHOLD_MEAT=20
